<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2026 生命精密防御实验室·旗舰版</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #6366f1;
            --danger: #f43f5e;
            --warning: #f59e0b;
            --success: #10b981;
            --bg: #030712;
            --card: #111827;
            --text: #f9fafb;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: var(--bg);
            color: var(--text);
            padding-bottom: 50px;
            line-height: 1.6;
        }
        header {
            background: linear-gradient(135deg, #1e1b4b, #312e81);
            padding: 40px 20px;
            text-align: center;
            border-bottom: 3px solid var(--primary);
        }
        header h1 {
            font-size: clamp(1.4rem, 4vw, 2rem);
            margin-bottom: 8px;
        }
        header p {
            color: #c7d2fe;
            font-size: 0.9rem;
        }
        .wrapper {
            max-width: 1400px;
            margin: -40px auto 0;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 400px 1fr;
            gap: 30px;
        }
        @media (max-width: 992px) {
            .wrapper {
                grid-template-columns: 1fr;
            }
        }
        .card {
            background: var(--card);
            border-radius: 24px;
            padding: 25px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }
        h2 {
            font-size: 1.2rem;
            color: var(--primary);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .control-panel {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .input-row {
            background: rgba(31, 41, 55, 0.4);
            padding: 15px;
            border-radius: 14px;
            border: 1px solid rgba(255,255,255,0.02);
        }
        .input-row.warn {
            border: 1px dashed var(--warning);
        }
        label {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: #9ca3af;
            margin-bottom: 8px;
        }
        input[type="range"] {
            width: 100%;
            accent-color: var(--primary);
            cursor: pointer;
        }
        .status-banner {
            padding: 15px;
            border-radius: 12px;
            font-weight: bold;
            text-align: center;
            margin-bottom: 20px;
            transition: all 0.3s ease;
        }
        .low {
            background: rgba(16, 185, 129, 0.15);
            color: var(--success);
            border: 1px solid var(--success);
        }
        .high {
            background: rgba(244, 63, 94, 0.15);
            color: var(--danger);
            border: 1px solid var(--danger);
        }
        .check-item {
            background: rgba(255,255,255,0.03);
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 10px;
            border-left: 4px solid #374151;
            font-size: 0.85rem;
        }
        .check-item.urgent {
            border-left-color: var(--danger);
            background: rgba(244, 63, 94, 0.1);
        }
        .edu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 25px;
        }
        .edu-box {
            padding: 18px;
            border-radius: 16px;
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
        }
        .edu-box h3 {
            color: var(--success);
            font-size: 1rem;
            margin-top: 0;
        }
        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        th {
            text-align: left;
            color: var(--primary);
            padding: 12px;
            border-bottom: 2px solid #334155;
        }
        td {
            padding: 12px;
            border-bottom: 1px solid #1f2937;
        }
        .switch-box {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
            padding: 12px;
            background: rgba(99, 102, 241, 0.1);
            border-radius: 10px;
            border: 1px solid var(--primary);
        }
    </style>
</head>
<body>

<header>
    <h1>🩺 2026 生命周期健康精密防御终端</h1>
    <p>Black-Scholes 风险建模 · CTA 影像联动 · 动态医学干预</p>
</header>

<div class="wrapper">
    <aside class="control-panel">
        <div class="card">
            <h2>🎛️ 风险因子输入</h2>
            <div class="input-row">
                <label>年龄基础: <b id="l-age">45 岁</b></label>
                <input type="range" id="age" min="20" max="90" value="45">
            </div>
            <div class="input-row">
                <label>收缩压 (mmHg): <b id="l-bp">120</b></label>
                <input type="range" id="bp" min="90" max="200" value="120">
            </div>
            <div class="input-row">
                <label>空腹血糖 (mmol/L): <b id="l-glu">5.2</b></label>
                <input type="range" id="glu" min="3.0" max="15.0" step="0.1" value="5.2">
            </div>
            <div class="input-row warn">
                <label>冠脉狭窄 (CTA%): <b id="l-cta">0%</b></label>
                <input type="range" id="cta" min="0" max="95" value="0">
            </div>

            <div class="switch-box">
                <input type="checkbox" id="treat">
                <label for="treat" style="margin:0; color:var(--success); font-weight:bold; cursor:pointer;">开启医学对冲 (药物+生活干预)</label>
            </div>

            <h2 style="margin-top:25px;">📋 动态检查路径</h2>
            <div id="check-list"></div>
        </div>
    </aside>

    <main>
        <div class="card">
            <h2>📈 健康资产储备与标准线对照</h2>
            <div style="height: 350px;">
                <canvas id="mainChart"></canvas>
            </div>
            <div id="risk-status" class="status-banner low">健康状态：优良</div>
        </div>

        <div class="edu-grid">
            <div class="edu-box">
                <h3>💊 治疗对冲与“价值锚定”</h3>
                <p><b>高血压/糖尿病：</b> 2026 指南强调“心肾共防”。开启对冲后，模型会模拟 SGLT2i 和 ACEI 药物对血管内皮的修复，使原本下坠的曲线趋于平缓。</p>
                <p><b>CTA 干预：</b> 若狭窄 > 50%，强化他汀治疗可实现斑块逆转，这是生命资产的“底部回升”。</p>
            </div>
            <div class="edu-box">
                <h3>🗓️ 2026 四月行动指南</h3>
                <p><b>窗口期宣教：</b> 目前呼吸道活性低位，建议完成 <b>胃肠镜</b> 与 <b>CTA</b> 等高阶检查。关注新兴虫媒病 Oropouche 监测，踏青注意防护。</p>
                <p><b>CKD 预警：</b> UACR 异常即为红灯，不看尿常规，看微量白蛋白比值。</p>
            </div>
        </div>

        <div class="card" style="margin-top:25px;">
            <h2>📑 进阶检查标准清单 (2026 版)</h2>
            <table>
                <thead>
                    <tr>
                        <th>类别</th>
                        <th>项目 (Gold Standard)</th>
                        <th>健康标准/临床干预</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><b>心血管</b></td>
                        <td>冠脉 CTA / 颈动脉超声</td>
                        <td>钙化积分 <10；狭窄 >70% 需介入干预。</td>
                    </tr>
                    <tr>
                        <td><b>肾脏代谢</b></td>
                        <td>UACR / eGFR / lp(a)</td>
                        <td>UACR <30mg/g；lp(a) 高需强化降脂。</td>
                    </tr>
                    <tr>
                        <td><b>癌症筛查</b></td>
                        <td>LDCT (肺) / 胃肠镜</td>
                        <td>50岁以上每年 LDCT；发现息肉即刻切除。</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>
</div>

<script>
    let chart;
    let debounceTimer;

    const items = [
        { n: "基础代谢全套", t: "base", d: "血压/血脂/血糖，生命的三大基石。" },
        { n: "UACR (心肾联测)", t: "ckd", d: "捕捉尿常规无法发现的早期肾损。" },
        { n: "冠脉 CTA 影像", t: "cta", d: "直观评估斑块稳定性与狭窄度。" },
        { n: "低剂量 CT / 胃肠镜", t: "cancer", d: "高发癌种的唯一早诊早治路径。" }
    ];

    // 防抖：滑动时不频繁重绘
    function run() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            calcAndRender();
        }, 80);
    }

    function calcAndRender() {
        const age = +document.getElementById('age').value;
        const bp = +document.getElementById('bp').value;
        const glu = +document.getElementById('glu').value;
        const cta = +document.getElementById('cta').value;
        const treat = document.getElementById('treat').checked;

        document.getElementById('l-age').textContent = age + ' 岁';
        document.getElementById('l-bp').textContent = bp;
        document.getElementById('l-glu').textContent = glu;
        document.getElementById('l-cta').textContent = cta + '%';

        // 检查列表
        const list = document.getElementById('check-list');
        list.innerHTML = '';
        items.forEach(i => {
            const isUrgent =
                (i.t === 'ckd' && (bp > 135 || glu > 7)) ||
                (i.t === 'cta' && bp > 145) ||
                (i.t === 'cancer' && age >= 50);
            list.innerHTML += `
                <div class="check-item ${isUrgent ? 'urgent' : ''}">
                    <span style="font-weight:bold; display:block;">${i.n} ${isUrgent ? '⚠️ 高危推荐' : ''}</span>
                    <span style="font-size:0.75rem; color:#94a3b8;">${i.d}</span>
                </div>`;
        });

        // 风险评分
        let riskScore = (bp - 115) * 0.4 + (glu - 5) * 8 + (cta * 0.6) + (age * 0.1);
        const statusEl = document.getElementById('risk-status');

        if (treat) riskScore *= 0.35;

        if (riskScore > 30) {
            statusEl.textContent = "警告：健康资产正加速损耗";
            statusEl.className = "status-banner high";
        } else {
            statusEl.textContent = "状态：健康储备稳健";
            statusEl.className = "status-banner low";
        }

        const labels = ['2026', '2028', '2030', '2032', '2034', '2036'];
        const standard = [100, 97, 92, 85, 76, 65];
        const realData = standard.map((v, i) =>
            Math.max(0, v - (riskScore * i * 0.12)).toFixed(0)
        );

        chart.data.labels = labels;
        chart.data.datasets[0].data = standard;
        chart.data.datasets[1].data = realData;
        chart.data.datasets[1].borderColor = treat ? '#10b981' : '#f43f5e';
        chart.update();
    }

    // 初始化图表
    function initChart() {
        const ctx = document.getElementById('mainChart').getContext('2d');
        chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: [],
                datasets: [
                    {
                        label: 'WHO 健康人群标准线',
                        data: [],
                        borderColor: 'rgba(52, 211, 153, 0.5)',
                        borderDash: [5, 5],
                        fill: false,
                        pointRadius: 0,
                        borderWidth: 2
                    },
                    {
                        label: '个体预期生命储备',
                        data: [],
                        borderColor: '#f43f5e',
                        borderWidth: 4,
                        fill: true,
                        backgroundColor: 'rgba(244, 63, 94, 0.05)',
                        tension: 0.3,
                        pointRadius: 3
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 400,
                    easing: 'easeOutQuart'
                },
                scales: {
                    y: {
                        min: 0,
                        max: 100,
                        grid: { color: '#334155' },
                        ticks: { color: '#94a3b8' }
                    },
                    x: {
                        ticks: { color: '#94a3b8' }
                    }
                },
                plugins: {
                    legend: {
                        labels: { color: '#fff', font: { size: 12 } }
                    }
                }
            }
        });
    }

    // 绑定事件
    function bindEvents() {
        const inputs = document.querySelectorAll('input[type="range"], input[type="checkbox"]');
        inputs.forEach(el => {
            el.addEventListener('input', run);
        });
    }

    // 启动
    window.addEventListener('DOMContentLoaded', () => {
        initChart();
        bindEvents();
        run();
    });
</script>
</body>
</html>
